# ═══════════════════════════════════════════════════════════
#  BotPay Center — Variables de entorno
#  Copia este archivo como .env y completa los valores
# ═══════════════════════════════════════════════════════════

# ── Aplicación ───────────────────────────────────────────
NODE_ENV=production
PORT=4000
APP_PORT=4080
FRONTEND_URL=http://localhost:4080

# ── Base de datos PostgreSQL ─────────────────────────────
DB_HOST=botpay-postgres
DB_PORT=5432
DB_NAME=botpay_db
DB_USER=botpay
DB_PASSWORD=CAMBIA_ESTA_CLAVE_SEGURA
DB_PORT_EXPOSE=5434

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=botpay-redis
REDIS_PORT=6379
REDIS_PORT_EXPOSE=6380

# ── JWT (CRM agentes) ─────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTE_SECRET_JWT_MUY_LARGO
JWT_EXPIRES_IN=8h

# ── Meta / WhatsApp Business Cloud API ──────────────────
META_APP_ID=TU_META_APP_ID
META_APP_SECRET=TU_META_APP_SECRET
META_PHONE_NUMBER_ID=TU_PHONE_NUMBER_ID
META_ACCESS_TOKEN=TU_ACCESS_TOKEN_PERMANENTE
META_WEBHOOK_VERIFY_TOKEN=TOKEN_VERIFICACION_WEBHOOK
META_API_VERSION=v20.0

# ── Configuración del negocio (Agente Recepcionista) ────
# Tipos: ropa | salud | comida | belleza | tecnologia | general
BUSINESS_TYPE=general
BUSINESS_NAME=Mi Negocio
BUSINESS_HOURS=8:00-18:00
BUSINESS_TZ=America/La_Paz

# ── PayCenter Integration ────────────────────────────────
# URL base del API de PayCenter
PAYCENTER_API_URL=http://localhost:3000/api/v1/bo
# Debe ser el mismo JWT_SECRET que usa PayCenterProject
PAYCENTER_JWT_SECRET=mismo_jwt_secret_que_paycenter
# ID del merchant en PayCenter (tabla merchant.id)
PAYCENTER_MERCHANT_ID=1
# Banco por defecto: bmsc | bnb | bisa
PAYCENTER_DEFAULT_BANK=bmsc
# Números de cuenta bancaria por banco
PAYCENTER_ACCOUNT_BMSC=
PAYCENTER_ACCOUNT_BNB=
PAYCENTER_ACCOUNT_BISA=

# Secret para validar callbacks de PayCenter → BotPay
PAYCENTER_CALLBACK_SECRET=SECRET_PARA_CALLBACK_PAGO
# Callback URL que configurar en PayCenter:
# http://TU_DOMINIO/api/paycenter/payment-callback
