# ─────────────────────────────────────────────────────────
# BotPay Center — Variables de entorno (PRODUCCIÓN)
# Copiá este archivo a .env y completá los valores
# ─────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Base de datos ─────────────────────────────────────────
DB_DIALECT=sqlite
DB_STORAGE=./data/botpay.db

# ── Autenticación interna ─────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_seguro
JWT_EXPIRES_IN=8h

# ── Meta / WhatsApp ───────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_API_VERSION=v20.0
META_WEBHOOK_VERIFY_TOKEN=

# ── PayCenter ─────────────────────────────────────────────
PAYCENTER_API_URL=https://api.paycenter.bo/api/v1/bo
PAYCENTER_MERCHANT_ID=
PAYCENTER_JWT_SECRET=
PAYCENTER_DEFAULT_BANK=bmsc
PAYCENTER_SECRET=
PAYCENTER_ACCOUNT_BMSC=
PAYCENTER_ACCOUNT_BCP=

# ── Negocio ───────────────────────────────────────────────
BUSINESS_NAME=PayCenter
BUSINESS_TYPE=pagos
BUSINESS_HOURS=8:00-18:00
BUSINESS_TZ=America/La_Paz

# ── Servicios externos — Agua ─────────────────────────────
SAGUAPAC_URL=https://api.saguapac.bo/v1
SAGUAPAC_AUTH_TYPE=apikey
SAGUAPAC_API_KEY=
SEMAPA_URL=https://api.semapa.gob.bo/v1
SEMAPA_API_KEY=

# ── Servicios externos — Electricidad ────────────────────
ELFEC_URL=https://api.elfec.bo/servicios/v2
ELFEC_HMAC_KEY=
CRE_URL=https://webservice.cre.com.bo/api
CRE_USER=
CRE_PASS=

# ── Servicios externos — Telecom ─────────────────────────
ENTEL_URL=https://api.entel.bo/partners/v1
ENTEL_JWT_SECRET=
TIGO_URL=https://api.tigo.com.bo/v1
TIGO_API_KEY=
VIVA_URL=https://api.vivabo.com.bo/v1
VIVA_API_KEY=

# ── Servicios externos — Impuestos ───────────────────────
GAMC_URL=https://api.cochabamba.bo/recaudaciones/v1
GAMC_API_KEY=
SIN_URL=https://servicios.impuestos.gob.bo/api/v1
SIN_HMAC_KEY=

# ── Servicios externos — Educación ───────────────────────
UCB_URL=https://pagos.ucbcba.edu.bo/api
UCB_API_KEY=
UMSS_URL=https://pagos.umss.edu.bo/api/v1
UMSS_API_KEY=
