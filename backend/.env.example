# ═══════════════════════════════════════════════════════════════
#  BotPay Center — Variables de entorno
#
#  USO:
#    cp backend/.env.example backend/.env
#    Completar cada valor marcado con <...>
#
#  PUERTOS RESERVADOS POR PAYCENTER (no usar):
#    3000-3007  servicios PayCenter (central + adaptadores)
#    5433       PostgreSQL de Keycloak (PayCenter)
#    8080-8081  Keycloak
#    80         Nginx PayCenter
# ═══════════════════════════════════════════════════════════════

# ── Aplicación ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_PORT=4080
FRONTEND_URL=http://localhost:4080

# ── Base de datos PostgreSQL ─────────────────────────────────────
# Local sin Docker:
#   DB_HOST=localhost  DB_PORT=5434
# Dentro de Docker Compose:
#   DB_HOST=botpay-postgres  DB_PORT=5432
DB_HOST=localhost
DB_PORT=5434
DB_NAME=botpay_db
DB_USER=botpay
DB_PASSWORD=<contraseña_segura>
DB_PORT_EXPOSE=5434

# ── Redis ─────────────────────────────────────────────────────────
# Local sin Docker:
#   REDIS_HOST=localhost  REDIS_PORT=6380
# Dentro de Docker Compose:
#   REDIS_HOST=botpay-redis  REDIS_PORT=6379
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PORT_EXPOSE=6380

# ── JWT — autenticación agentes CRM ──────────────────────────────
# Generar con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<genera_un_secret_largo>
JWT_EXPIRES_IN=8h

# ── Meta / WhatsApp Business Cloud API ───────────────────────────
# Obtener desde: https://developers.facebook.com/apps/
META_APP_ID=<tu_app_id>
META_APP_SECRET=<tu_app_secret>
META_PHONE_NUMBER_ID=<tu_phone_number_id>
META_WABA_ID=<tu_waba_id>
META_ACCESS_TOKEN=<tu_access_token_permanente>
META_WEBHOOK_VERIFY_TOKEN=<token_que_configuraste_en_meta>
META_API_VERSION=v20.0

# ── Negocio (Agente Recepcionista) ────────────────────────────────
# BUSINESS_TYPE: pagos | ropa | salud | comida | belleza | tecnologia | general
BUSINESS_TYPE=pagos
BUSINESS_NAME=<nombre_del_negocio>
BUSINESS_HOURS=8:00-20:00
BUSINESS_TZ=America/La_Paz

# ── PayCenter — integración de pagos QR ──────────────────────────
# Autenticación: OAuth2 Client Credentials via Keycloak
#
# Flujo:
#   1. BotPay solicita token a Keycloak con CLIENT_ID + CLIENT_SECRET
#   2. Usa el Bearer token en cada llamada a PayCenter
#
# URL base del API de PayCenter
PAYCENTER_API_URL=http://localhost:3000/api/v1/bo

# Endpoint token de Keycloak (te lo provee el equipo de PayCenter)
PAYCENTER_TOKEN_URL=https://test.api.pay-center.cloud/realms/Pay-Center/protocol/openid-connect/token

# Credenciales del cliente en Keycloak (te las provee el equipo de PayCenter)
PAYCENTER_CLIENT_ID=<tu_client_id_keycloak>
PAYCENTER_CLIENT_SECRET=<tu_client_secret_keycloak>

# ID del merchant registrado en PayCenter
PAYCENTER_MERCHANT_ID=1

# Banco por defecto para QRs (verificar código exacto con PayCenter)
# Ejemplo: bis | bnb | bmsc
PAYCENTER_DEFAULT_BANK=bis

# Número de cuenta bancaria registrada en PayCenter por banco
PAYCENTER_ACCOUNT_BIS=<numero_cuenta_bis>
PAYCENTER_ACCOUNT_BNB=<numero_cuenta_bnb>
PAYCENTER_ACCOUNT_BMSC=<numero_cuenta_bmsc>

# ── PayCenter Callback ────────────────────────────────────────────
# Secret para verificar que el callback viene de PayCenter
PAYCENTER_CALLBACK_SECRET=<secret_para_validar_callback>
# URL a registrar en PayCenter como webhook de pago:
#   https://<tu_dominio>/api/paycenter/payment-callback

# ── Modo mock (solo desarrollo sin PayCenter real) ────────────────
# true  → genera QRs simulados (sin necesitar PayCenter)
# false → usa PayCenter real
PAYCENTER_MOCK=true
