# ═══════════════════════════════════════════════════════════
#  BotPay Center — Variables de entorno
#  Copia este archivo como .env y completa los valores
# ═══════════════════════════════════════════════════════════

# ── Aplicación ───────────────────────────────────────────
NODE_ENV=production
PORT=4000
APP_PORT=4080
FRONTEND_URL=http://localhost:4080

# ── Base de datos PostgreSQL ─────────────────────────────
DB_HOST=botpay-postgres
DB_PORT=5432
DB_NAME=botpay_db
DB_USER=botpay
DB_PASSWORD=CAMBIA_ESTA_CLAVE_SEGURA
DB_PORT_EXPOSE=5434

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=botpay-redis
REDIS_PORT=6379
REDIS_PORT_EXPOSE=6380

# ── JWT (CRM agentes) ─────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTE_SECRET_JWT_MUY_LARGO
JWT_EXPIRES_IN=8h

# ── Meta / WhatsApp Business Cloud API ──────────────────
META_APP_ID=TU_META_APP_ID
META_APP_SECRET=TU_META_APP_SECRET
META_PHONE_NUMBER_ID=TU_PHONE_NUMBER_ID
META_ACCESS_TOKEN=TU_ACCESS_TOKEN_PERMANENTE
META_WEBHOOK_VERIFY_TOKEN=TOKEN_VERIFICACION_WEBHOOK
META_API_VERSION=v20.0

# ── Configuración del negocio (Agente Recepcionista) ────
# Tipos: ropa | salud | comida | belleza | tecnologia | general
BUSINESS_TYPE=general
BUSINESS_NAME=Mi Negocio
BUSINESS_HOURS=8:00-18:00
BUSINESS_TZ=America/La_Paz

# ── PayCenter Integration ────────────────────────────────
# Autenticación: OAuth2 Client Credentials via Keycloak (máquina a máquina)
# BotPay obtiene un Bearer token de Keycloak y lo usa en cada llamada.

# URL base del API de PayCenter
PAYCENTER_API_URL=https://test.api.pay-center.cloud/api/v1/bo

# Endpoint de token Keycloak (provisto por PayCenter)
PAYCENTER_TOKEN_URL=https://test.api.pay-center.cloud/realms/Pay-Center/protocol/openid-connect/token

# Credenciales del cliente Keycloak (te las provee el equipo de PayCenter)
PAYCENTER_CLIENT_ID=TU_CLIENT_ID
PAYCENTER_CLIENT_SECRET=TU_CLIENT_SECRET

# ID del merchant registrado en PayCenter
PAYCENTER_MERCHANT_ID=1

# Banco por defecto para generar QRs (verificar códigos con PayCenter)
PAYCENTER_DEFAULT_BANK=bis

# Número de cuenta bancaria por banco (registrada en PayCenter)
PAYCENTER_ACCOUNT_BIS=
PAYCENTER_ACCOUNT_BNB=
PAYCENTER_ACCOUNT_BMSC=

# Secret para validar callbacks de PayCenter → BotPay
PAYCENTER_CALLBACK_SECRET=SECRET_PARA_CALLBACK_PAGO
# Callback URL a registrar en PayCenter:
# https://TU_DOMINIO/api/paycenter/payment-callback

# ── Modo mock (desarrollo sin PayCenter real) ────────────
# true  → genera QRs simulados cuando no hay credenciales
# false → usa PayCenter real
PAYCENTER_MOCK=false
